# Copy to `.env` in this directory (docker/) and fill in what you need.
# docker-compose automatically picks these up.
#
# Set CONFIG_FILE, CONFIG_URL, both, or neither. With neither, the container
# serves the baked-in default config (Welcome screen).

# Path to a local config.json (relative to docker/ or absolute). Bind-mounted
# into the container at startup.
# CONFIG_FILE=../examples/config-flyefish.json

# URL the SPA fetches in the browser at page load. Entirely client-side;
# equivalent to visiting /?config=<url>.
# CONFIG_URL=https://example.com/my-config.json
